# Tạo một mảng với các giá trị thập phân và làm tròn chúng về số nguyên gần nhất
roundArr = np.array([-1.7, -0.5, -0.2, 0.5, 1.2, 1.5])
roundArr_rounded = np.sign(roundArr) * np.ceil(np.abs(roundArr))
print("\nMảng sau khi làm tròn:\n", roundArr_rounded)
# np.abs(Z) → lấy giá trị tuyệt đối
# np.ceil(...) → làm tròn lên (luôn ra xa 0)
# np.sign(Z) → khôi phục dấu âm/dương

