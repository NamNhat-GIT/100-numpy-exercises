# Tạo một ma trận 5x5 với các giá trị từ 0 đến 4 lặp lại trên mỗi hàng
matrix5x5 = np.tile(np.arange(5), (5, 1))
print("\nMa trận 5x5:\n", matrix5x5)
#np.tile: lặp mảng
#np.arange(5): mảng được lặp
#(5, 1): số lần lặp theo chiều dọc và chiều ngang
Z = np.zeros((5, 5))
Z += np.arange(5)
print("\nMa trận Z sau khi cộng với np.arange(5):\n", Z)
# np.zeros((5, 5)) tạo một ma trận 5x5 với tất cả phần tử là 0.
# np.zeros((5, 5)) += np.arange(5): NumPy sẽ tự động “mở rộng” mảng [0,1,2,3,4] để phù hợp với ma trận (5,5).

# Tạo một mảng từ một generator
