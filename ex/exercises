#Tính (A + B) * (-A / 2) tại chỗ
#Dùng copy() để tránh thay đổi A trước khi tính B, vì A sẽ bị thay đổi sau phép cộng với B.
A = np.array([[2, 4]])
B = np.array([[6, 8]])
tmp = A.copy()

A = A + B
B = tmp / 2
print("\n(A + B) * (-A / 2):\n", A * B)

#không dùng copy():
A, B = 6, 4

B = A + B
A = -A / 2
print("\n(A + B) * (-A / 2) mà không dùng copy():\n", A * B)


